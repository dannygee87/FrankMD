#!/bin/bash
set -e

IMAGE="akitaonrails/frankmd:latest"
SERVER="192.168.0.90"
COMPOSE_DIR="/var/opt/docker/utils"
COMPOSE_FILE="docker-compose.yml"
SERVICE="frankmd"
SSH_OPTS="-F /dev/null"

echo "==> Building image..."
docker build -t "$IMAGE" .

echo "==> Pushing image..."
docker push "$IMAGE"

echo "==> Deploying to $SERVER..."
ssh $SSH_OPTS "$SERVER" "cd $COMPOSE_DIR && docker compose -f $COMPOSE_FILE stop $SERVICE && docker compose -f $COMPOSE_FILE pull $SERVICE && docker compose -f $COMPOSE_FILE up -d $SERVICE"

echo "==> Done!"
